{
  "name": "sundial-editor",
  "displayName": "Sundial Editor",
  "description": "A focused collaboration prompt surface for Sundial editing workflows.",
  "version": "0.18.0",
  "publisher": "arcridge",
  "license": "Apache-2.0",
  "homepage": "https://github.com/bjackson-arcridge/sundial-editor/tree/main/packages/editor#readme",
  "bugs": {
    "url": "https://github.com/bjackson-arcridge/sundial-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjackson-arcridge/sundial-editor.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "ai",
    "agents",
    "editor",
    "collaboration",
    "sundial"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "icon": "media/sundial_vscode_icon_slate_lemon_256.png",
  "files": [
    "dist",
    "media",
    "README.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sundialEditor.submitPrompt",
    "onCommand:sundialEditor.task.question",
    "onCommand:sundialEditor.task.questionProject",
    "onCommand:sundialEditor.task.deepResearch",
    "onCommand:sundialEditor.task.deepResearchProject",
    "onCommand:sundialEditor.task.fix",
    "onCommand:sundialEditor.task.fixProject",
    "onCommand:sundialEditor.task.write",
    "onCommand:sundialEditor.task.writeProject",
    "onCommand:sundialEditor.task.refactor",
    "onCommand:sundialEditor.task.refactorProject",
    "onCommand:sundialEditor.task.cleanup",
    "onCommand:sundialEditor.task.cleanupProject",
    "onCommand:sundialEditor.task.test",
    "onCommand:sundialEditor.task.testProject",
    "onView:sundialEditor.messages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sundialEditor.submitPrompt",
        "title": "Sundial Editor: Submit Prompt",
        "icon": "$(send)"
      },
      { "command": "sundialEditor.task.question", "title": "Sundial Editor: Create Question Task for Current Line" },
      { "command": "sundialEditor.task.questionProject", "title": "Sundial Editor: Create Project Question Task" },
      { "command": "sundialEditor.task.deepResearch", "title": "Sundial Editor: Create Deep Research Task for Current Line" },
      { "command": "sundialEditor.task.deepResearchProject", "title": "Sundial Editor: Create Project Deep Research Task" },
      { "command": "sundialEditor.task.fix", "title": "Sundial Editor: Create Fix Task for Current Line" },
      { "command": "sundialEditor.task.fixProject", "title": "Sundial Editor: Create Project Fix Task" },
      { "command": "sundialEditor.task.write", "title": "Sundial Editor: Create Write Task for Current Line" },
      { "command": "sundialEditor.task.writeProject", "title": "Sundial Editor: Create Project Write Task" },
      { "command": "sundialEditor.task.refactor", "title": "Sundial Editor: Create Refactor Task for Current Line" },
      { "command": "sundialEditor.task.refactorProject", "title": "Sundial Editor: Create Project Refactor Task" },
      { "command": "sundialEditor.task.cleanup", "title": "Sundial Editor: Create Cleanup Task for Current Line" },
      { "command": "sundialEditor.task.cleanupProject", "title": "Sundial Editor: Create Project Cleanup Task" },
      { "command": "sundialEditor.task.test", "title": "Sundial Editor: Create Test Task for Current Line" },
      { "command": "sundialEditor.task.testProject", "title": "Sundial Editor: Create Project Test Task" },
      { "command": "sundialEditor.diff.toggle", "title": "Sundial Editor: Toggle Diff View" },
      { "command": "sundialEditor.diff.inline", "title": "Sundial Editor: Toggle Inline Diff" },
      { "command": "sundialEditor.diff.previous", "title": "Sundial Editor: Diff Baseline Previous Commit" },
      { "command": "sundialEditor.diff.next", "title": "Sundial Editor: Diff Baseline Next Commit" },
      { "command": "sundialEditor.diff.head", "title": "Sundial Editor: Diff Baseline HEAD" },
      { "command": "sundialEditor.diff.permanent", "title": "Sundial Editor: Diff Baseline Last Permanent Commit" },
      { "command": "sundialEditor.commit.file", "title": "Sundial Editor: Create Temporary Commit for Current File" },
      { "command": "sundialEditor.commit.all", "title": "Sundial Editor: Create Temporary Commit for All Changes" },
      { "command": "sundialEditor.commit.message", "title": "Sundial Editor: Consolidate Temporary Commits" },
      { "command": "sundialEditor.companions.repair", "title": "Sundial Editor: Repair Annotation Companions" }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "sundialEditor",
          "title": "Sundial Agents",
          "icon": "media/sundial.svg"
        }
      ]
    },
    "views": {
      "sundialEditor": [
        {
          "id": "sundialEditor.messages",
          "name": "Messages",
          "type": "webview",
          "icon": "media/sundial.svg"
        }
      ]
    },
    "configuration": {
      "title": "Sundial Editor",
      "properties": {
        "sundialEditor.cliPath": {
          "type": "string",
          "default": "sundial-editor-cli",
          "description": "Path or executable name for the locally installed Sundial Editor CLI."
        },
        "sundialEditor.paneSplitPercent": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 90,
          "scope": "window",
          "description": "Percentage of the Messages view height allocated to the Agents pane. Resizing the pane separator updates this setting."
        }
      }
    },
    "configurationDefaults": {
      "files.autoSave": "afterDelay",
      "files.autoSaveDelay": 1000
    },
    "menus": {
      "commandPalette": [
        {
          "command": "sundialEditor.submitPrompt"
        },
        {
          "command": "sundialEditor.task.question"
        },
        {
          "command": "sundialEditor.task.questionProject"
        },
        {
          "command": "sundialEditor.task.deepResearch"
        },
        {
          "command": "sundialEditor.task.deepResearchProject"
        },
        {
          "command": "sundialEditor.task.fix"
        },
        {
          "command": "sundialEditor.task.fixProject"
        },
        {
          "command": "sundialEditor.task.write"
        },
        {
          "command": "sundialEditor.task.writeProject"
        },
        {
          "command": "sundialEditor.task.refactor"
        },
        {
          "command": "sundialEditor.task.refactorProject"
        },
        {
          "command": "sundialEditor.task.cleanup"
        },
        {
          "command": "sundialEditor.task.cleanupProject"
        },
        {
          "command": "sundialEditor.task.test"
        },
        {
          "command": "sundialEditor.task.testProject"
        }
      ]
    }
  },
  "scripts": {
    "prepack": "npm run package",
    "vscode:prepublish": "npm run package",
    "precheck-types": "npm run compile --workspace @arcridge/sundial-editor-annotations",
    "check-types:host": "tsc --noEmit",
    "check-types:webview": "tsc --noEmit -p tsconfig.webview.json",
    "check-types": "npm run check-types:host && npm run check-types:webview",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:annotations": "npm run compile --workspace @arcridge/sundial-editor-annotations -- --watch",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:tsc-webview": "tsc --noEmit --watch -p tsconfig.webview.json",
    "package": "npm run check-types && node esbuild.js --production",
    "package:vsix": "vsce package --no-dependencies",
    "precompile-tests": "npm run compile --workspace @arcridge/sundial-editor-annotations",
    "compile-tests": "tsc -p . --outDir out",
    "test:unit": "npm run compile-tests && node --test out/unit/*.test.js",
    "watch-tests": "tsc -p . -w --outDir out",
    "prepare-test-workspaces": "node src/test/prepare-workspaces.mjs",
    "prepare-test-runtime": "node ../../scripts/prepare-vscode-test-runtime.mjs",
    "pretest": "npm --prefix ../cli run compile && npm run compile-tests && npm run compile && npm run prepare-test-workspaces && npm run prepare-test-runtime",
    "test": "vscode-test --config .vscode-test.mjs"
  },
  "devDependencies": {
    "@arcridge/sundial-editor-annotations": "0.1.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@vscode/codicons": "^0.0.45",
    "lit": "^3.3.2",
    "markdown-it": "^14.3.0"
  }
}
