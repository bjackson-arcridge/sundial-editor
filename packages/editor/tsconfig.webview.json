{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/webviews/apps/**/*.ts",
    "src/webviews/messages/messages.ts",
    "src/messageComposerKeyboard.ts",
    "src/promptCommand.ts"
  ]
}
