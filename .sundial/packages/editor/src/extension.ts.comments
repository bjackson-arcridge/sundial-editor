annotations:
  - {"kind":"agent","id":"agent-0fa3361209608a15a1d46ac2ef74f9a9","agentId":"ce1e8a00-b1b7-4f99-9a0c-6f4ad4f0468c","agentSessionId":"992c5328-6640-43c2-9aa3-8249a3f59cf2","body":"## Extension-host coordinator\n\n`MessagesWebviewProvider` is the host-side composition root. It connects the active editor location and annotation markers with the Messages view, and it owns the CLI-backed loading and mutations for agents, queued work, and annotations.\n\nWhen VS Code resolves the view, `resolveWebviewView` configures the webview, attaches the validated message router, and renders the HTML that loads the bundled client application.\n","createdAt":"2026-07-21T12:05:48.786Z","anchor":{"line":20,"text":"\tconst messagesProvider = new MessagesWebviewProvider(context.extensionUri, {","before":["\t\t\tmargin: '0 0.65em 0 0',","\t\t},","\t});"],"after":["\t\treturnToSource: returnToSource,","\t\trevealAnnotation: revealAnnotation,","\t\tshowAnnotationMarkers: (sourceUri, lines) => {"]},"userAnnotation":{"annotationId":"7d61322c-9ab7-4ca3-860b-78f99980e0ef","file":"packages/editor/src/webviews/messages/messages.ts","line":14}}
